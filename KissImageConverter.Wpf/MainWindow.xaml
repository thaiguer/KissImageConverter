<Window x:Class="KissImageConverter.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KissImageConverter.Wpf"
        mc:Ignorable="d"
        Title="Kiss Conversion"
        Width="600"
        Height="500"
        MinWidth="600"
        MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Grid AllowDrop="True"
          DragEnter="DropArea_DragEnter"
          DragOver="DropArea_DragOver"
          Drop="DropArea_Drop"
          Margin="12">

        <Border CornerRadius="8"
                Padding="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Convert HEIC to JPG"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <Border Grid.Row="1"
                        Name="DropArea"
                        BorderThickness="1"
                        BorderBrush="#10A37F"
                        CornerRadius="6"
                        Margin="0,0,0,10"
                        Cursor="Hand"
                        MouseLeftButtonUp="DropArea_Click">

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <TextBlock Text="📷"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   Foreground="#10A37F"/>

                        <TextBlock Text="Drag and drop .HEIC files"
                                   FontSize="13"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="or click to select"
                                   FontSize="10"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="2"
                           Text="Files"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <ListView Grid.Row="3"
                          ItemsSource="{Binding FileItems}"
                          BorderBrush="#10A37F">

                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Padding" Value="5"/>
                        </Style>

                        <Style TargetType="ListViewItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd"
                                                Padding="4">
                                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                                  Columns="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=View.Columns}"/>
                                        </Border>

                                        <ControlTemplate.Triggers>

                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                            </Trigger>

                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                            </Trigger>

                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                    </ListView.Resources>

                    <ListView.View>
                        <GridView>

                            <GridViewColumn Header="Name"
                                            DisplayMemberBinding="{Binding FilePath}" />

                            <GridViewColumn Header="Status"
                                            DisplayMemberBinding="{Binding Status}" />

                        </GridView>
                    </ListView.View>
                </ListView>

                <Grid Grid.Row="4"
                      Margin="0,0,0,10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Destination folder"
                               FontSize="11"
                               Margin="0,0,0,4"/>

                    <Grid Grid.Row="1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Name="TextBoxDestino"
                                 Height="30"
                                 Padding="6,4"
                                 BorderThickness="1"
                                 BorderBrush="#10A37F"/>

                        <Button Grid.Column="2"
                                Height="30"
                                Content="Browse..."
                                BorderThickness="1"
                                BorderBrush="#10A37F"
                                Cursor="Hand"
                                HorizontalAlignment="Stretch"
                                Click="ButtonBrowse_Click"/>

                        <Button Grid.Column="4"
                                Height="30"
                                Content="Open"
                                BorderThickness="1"
                                BorderBrush="#10A37F"
                                Cursor="Hand"
                                HorizontalAlignment="Stretch"
                                Click="ButtonOpenFolder_Click"/>
                    </Grid>
                </Grid>

                <ProgressBar Name="ProgressBar"
                             Grid.Row="5"
                             BorderThickness="0"/>

                <Grid Grid.Row="7">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Height="36"
                            Content="Clear"
                            FontWeight="SemiBold"
                            FontSize="13"
                            BorderThickness="1"
                            BorderBrush="#10A37F"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            Click="ButtonClear_Click"/>

                    <Button Grid.Column="2"
                            Name="ButtonConvert"
                            Height="36"
                            Content="Convert"
                            Background="#10A37F"
                            FontWeight="SemiBold"
                            FontSize="13"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            Click="Button_Click"/>
                </Grid>

                <TextBlock Grid.Row="8"
                           Name="TextBlockVersion"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Right"
                           FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>