<Window x:Class="KissImageConverter.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KissImageConverter.Wpf"
        mc:Ignorable="d"
        Title="Kiss Conversion"
        Width="600"
        Height="500"
        MinWidth="600"
        MinHeight="500"
        Background="#212121"
        WindowStartupLocation="CenterScreen">
    <Grid AllowDrop="True"
          DragEnter="DropArea_DragEnter"
          DragOver="DropArea_DragOver"
          Drop="DropArea_Drop"
          Margin="12">
        <Border Background="#2F2F2F"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="90" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Convert HEIC to JPG"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Margin="0,0,0,10" />

                <Border Grid.Row="1"
                        Name="DropArea"
                        Background="#404040"
                        BorderBrush="#606060"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="0,0,0,10">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="📷"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   Foreground="#10A37F" />
                        <TextBlock Text="Drag and drop .HEIC files here"
                                   FontSize="13"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="or click to select"
                                   FontSize="10"
                                   Foreground="#B0B0B0"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="2"
                           Text="Files"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Margin="0,0,0,4" />

                <ListBox Grid.Row="3"
                         Name="ListBoxFiles"
                         Background="#404040"
                         Foreground="White"
                         BorderBrush="#606060"
                         BorderThickness="1"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,10">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="4" />
                            <Setter Property="Margin" Value="1" />
                            <Setter Property="Foreground" Value="White" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <StackPanel Grid.Row="4"
                            Margin="0,0,0,10">
                    <TextBlock Text="Destination folder"
                               FontSize="11"
                               Foreground="#B0B0B0"
                               Margin="0,0,0,4" />
                    <TextBox Name="TextBoxDestino"
                             Height="30"
                             Padding="6,4"
                             Background="#404040"
                             Foreground="White"
                             BorderBrush="#606060"
                             BorderThickness="1" />
                </StackPanel>

                <ProgressBar Name="ProgressBar"
                             Grid.Row="5"
                             Background="#404040"
                             BorderThickness="0" />

                <Grid Grid.Row="7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Height="36"
                            Content="Clear"
                            Background="#505050"
                            Foreground="White"
                            FontWeight="SemiBold"
                            FontSize="13"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ButtonClear_Click" />

                    <Button Grid.Column="2"
                            Name="ButtonConvert"
                            Height="36"
                            Content="Convert"
                            Background="#10A37F"
                            Foreground="White"
                            FontWeight="SemiBold"
                            FontSize="13"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Button_Click" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>